{
  "name": "crmed",
  "version": "1.0.0",
  "description": "Sistema Inteligente de Relacionamento e Performance Clínica - Hospital São Rafael",
  "private": true,
  "scripts": {
    "infra:up": "cd infra/docker && docker compose --env-file ../../.env up -d postgres redis evolution-api",
    "infra:down": "cd infra/docker && docker compose --env-file ../../.env down",
    "infra:dev": "pnpm infra:up && pnpm -F @crmed/database db:push && pnpm -F @crmed/database db:seed && pnpm dev",
    "dev": "kill-port 3000 3001 2>/dev/null || true && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run"
  },
  "keywords": [],
  "author": "Grupo Moskitto",
  "license": "ISC",
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "overrides": {
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.5",
      "esbuild": ">=0.25.0",
      "vite": ">=6.4.2",
      "uuid": ">=14.0.0",
      "lodash": ">=4.17.21",
      "lodash-es": ">=4.17.21",
      "minimatch": ">=3.1.2",
      "@apollo/server": ">=5.5.0",
      "@tootallnate/once": ">=3.0.1",
      "vitest": ">=3.2.4",
      "@vitest/coverage-v8": ">=3.2.4"
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "kill-port": "^2.0.1",
    "turbo": "^2.8.21",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
