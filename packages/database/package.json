{
  "name": "@crmed/database",
  "version": "1.0.0",
  "private": true,
  "main": "./src/index.ts",
  "scripts": {
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "@prisma/client": "^5"
  },
  "devDependencies": {
    "@crmed/config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.14.0",
    "prisma": "^5",
    "tsx": "^4"
  }
}
