generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum UserRole {
  ADMIN
  SURGEON
  CALL_CENTER
  RECEPTION
  SALES
}

model Lead {
  id               String     @id @default(cuid())
  name             String
  email            String     @unique
  phone            String
  cpf              String     @unique
  source           String
  origin           String?    // Instagram, TikTok, Google Ads, Indicação, Site
  procedure        String?    // Procedimento de interesse
  preferredDoctor  String?    // ID do médico preferido
  whatsappActive  Boolean    @default(false)
  notes            String?
  status           LeadStatus @default(NEW)
  createdAt        DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  patient        Patient?
  appointments   Appointment[]
  contacts       Contact[]

  @@index([cpf])
  @@index([email])
  @@index([phone])
  @@index([status])
}

model Patient {
  id            String   @id @default(cuid())
  leadId        String   @unique
  dateOfBirth   DateTime
  medicalRecord String?  @unique
  address       String?  // Endereço completo

  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  documents     Document[]
  postOps       PostOp[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leadId])
}

model Surgeon {
  id           String   @id @default(cuid())
  name         String
  specialty    String
  crm          String   @unique
  email        String   @unique
  phone        String
  isActive     Boolean  @default(true)

  appointments Appointment[]
  availability AvailabilitySlot[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([crm])
}

model AvailabilitySlot {
  id         String   @id @default(cuid())
  surgeonId  String
  dayOfWeek  Int
  startTime  String
  endTime    String
  isActive   Boolean  @default(true)

  surgeon    Surgeon   @relation(fields: [surgeonId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([surgeonId])
  @@index([dayOfWeek])
}

model Appointment {
  id          String            @id @default(cuid())
  patientId   String
  surgeonId   String
  procedure   String
  scheduledAt DateTime
  status      AppointmentStatus @default(SCHEDULED)
  notes       String?

  patient     Lead              @relation(fields: [patientId], references: [id])
  surgeon     Surgeon           @relation(fields: [surgeonId], references: [id])

  auditLogs   AuditLog[]
  notifications Notification[]

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([patientId])
  @@index([surgeonId])
  @@index([scheduledAt])
  @@index([status])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(CALL_CENTER)
  isActive  Boolean  @default(true)

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
}

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  oldValue      Json?
  newValue      Json?
  reason        String?

  userId        String?
  appointmentId String?

  user          User?        @relation(fields: [userId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  createdAt     DateTime     @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([appointmentId])
  @@index([createdAt])
}

enum NotificationType {
  CONFIRMATION
  REMINDER_2_DAYS
  REMINDER_1_DAY
  LAST_ATTEMPT
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id            String             @id @default(cuid())
  appointmentId String
  type          NotificationType
  status        NotificationStatus @default(PENDING)
  sentAt        DateTime?
  errorMessage  String?

  appointment   Appointment        @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  createdAt     DateTime           @default(now())

  @@index([appointmentId])
  @@index([status])
  @@index([type])
}

enum ContactType {
  WHATSAPP
  CALL
  EMAIL
}

enum ContactDirection {
  INBOUND
  OUTBOUND
}

enum ContactStatus {
  SENT
  DELIVERED
  READ
  FAILED
  ANSWERED
  MISSED
}

model Contact {
  id          String          @id @default(cuid())
  leadId      String
  date        DateTime
  type        ContactType
  direction   ContactDirection
  status      ContactStatus
  message     String

  lead        Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([leadId])
  @@index([date])
}

enum DocumentType {
  CONTRACT
  TERM
  EXAM
  OTHER
}

enum DocumentStatus {
  PENDING
  SIGNED
  UPLOADED
}

model Document {
  id        String          @id @default(cuid())
  patientId String
  name      String
  type      DocumentType
  date      DateTime
  status    DocumentStatus  @default(PENDING)

  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt DateTime        @default(now())

  @@index([patientId])
}

enum PostOpType {
  RETURN
  REPAIR
}

enum PostOpStatus {
  SCHEDULED
  COMPLETED
  PENDING
}

model PostOp {
  id          String        @id @default(cuid())
  patientId   String
  date        DateTime
  type        PostOpType
  description String
  status      PostOpStatus @default(SCHEDULED)

  patient     Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())

  @@index([patientId])
  @@index([date])
}

enum MessageChannel {
  WHATSAPP
  SMS
  EMAIL
}

model MessageTemplate {
  id           String         @id @default(cuid())
  name         String         @unique
  channel      MessageChannel
  content      String
  triggerDays  Int            @default(0)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}
