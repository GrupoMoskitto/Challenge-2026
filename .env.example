# CRMed - Central Environment Variables
# Copy this file to .env and fill in the values

# WhatsApp Configuration
# DEV_ALLOWED_PHONE="5511999999999"  # Número com DDD (apenas este receberá mensagens em dev)
EVOLUTION_INSTANCE_NAME="crmed-whatsapp"

# Evolution API
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua_chave_aqui"

# Database (PostgreSQL)
DATABASE_URL="postgresql://crmed:crmed123@localhost:5432/crmed"
